        {
          "name": "tradeDetails",
          "type": "object",
          "label": "Trade Details ",
          "properties": [
            {
              "name": "financialYear",
              "type": "string",
              "label": "Financial Year ",
              "format": "radioordropdown",
              "schema": "egf-master.FinancialYear2",
              "required": false,
              "reference": "mdms",
              "orderNumber": 1
            },
            {
              "name": "licenseType",
              "type": "string",
              "label": "License Type ",
              "format": "radioordropdown",
              "required": false,
              "orderNumber": 2,
              "defaultValue": "PERMANENT"
            },
            {
              "name": "tradeName",
              "type": "string",
              "label": "Trade Name ",
              "format": "text",
              "required": false,
              "maxLength": 128,
              "minLength": 2,
              "validation": {
                "regex": "^[A-Za-z0-9 ]+$",
                "message": "Only letters and numbers allowed"
              },
              "orderNumber": 3
            },
            {
              "name": "tradeStructureType",
              "type": "string",
              "label": "Trade Structure Type ",
              "format": "radioordropdown",
              "schema": "Tradelicence.StructureType",
              "required": false,
              "reference": "mdms",
              "orderNumber": 4
            },
            {
              "name": "tradeStructureSubType",
              "type": "string",
              "label": "Trade Structure Sub Type ",
              "format": "radioordropdown",
              "schema": "Tradelicence.StructureSubType",
              "required": false,
              "reference": "mdms",
              "orderNumber": 5,
              "dependencies": [
                "tradeStructureType"
              ]
            },
            {
              "name": "tradeCommencementDate",
              "type": "date",
              "label": "Trade Commencement Date ",
              "format": "date",
              "required": false,
              "orderNumber": 6
            }
          ]
        },
        {
          "name": "tradeUnits",
          "type": "object",
          "label": "Trade Units ",
          "properties": [
            {
              "name": "tradeCategory",
              "type": "string",
              "label": "Trade Category ",
              "format": "radioordropdown",
